{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://compintel-scout.local/schema/competitor.schema.json",
  "title": "CompIntel Competitor",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "website", "category", "sources"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "website": {
      "type": "string",
      "format": "uri"
    },
    "category": {
      "type": "string",
      "enum": ["direct", "adjacent", "emerging", "unknown"]
    },
    "summary": {
      "type": "string"
    },
    "strengths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "weaknesses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
