{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RoleArchetype",
  "type": "object",
  "required": ["role_slug", "titles", "pain_points", "success_metrics"],
  "properties": {
    "role_slug": { "type": "string" },
    "titles": {
      "type": "array",
      "items": { "type": "string" }
    },
    "department": { "type": "string" },
    "pain_points": {
      "type": "array",
      "items": { "type": "string" }
    },
    "success_metrics": {
      "type": "array",
      "items": { "type": "string" }
    },
    "buying_triggers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "messaging_angles": {
      "type": "array",
      "items": { "type": "string" }
    },
    "preferred_channels": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
